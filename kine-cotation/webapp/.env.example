# Config KineCotation (backend server.py) — COPIER en .env, ne jamais commiter.
# Le plus simple : ne pas remplir a la main, lancer `python set_password.py`.

# Identifiant du kine (son email)
APP_USER=

# Hash PBKDF2 du mot de passe — genere par set_password.py, jamais le mdp en clair
APP_PASSWORD_HASH=

# Cle de signature des sessions — generee par set_password.py (48+ octets aleatoires)
SECRET_KEY=

# --- OCR : choix du provider IA (couche prototype/llm.py) ---
# Defaut CODE = mistral (souverainete FR/UE, cible prod). NE PAS changer ce defaut
# dans le code ; on le surcharge ICI pour le pilote Malcom.
#
# PILOTE MALCOM (decision Enzo) : on reutilise la cle Anthropic existante plutot
# que d'ouvrir un compte Mistral. Claude = meilleur des benchmarks (94,4 % mots
# medicaux, CER 0,94 %). Sonnet pour l'extraction (doctrine cout — PAS Opus, qui
# est le defaut anthropic de llm.py).
#   Nuance RGPD assumee : Anthropic = US. Acceptable AU PILOTE UNIQUEMENT parce que
#   le caviardage in-app est structurel (l'image part deja masquee, non nominative).
#   Cible souverainete (Mistral EU / local) inchangee pour la prod. Cf. 06/09.
KINE_LLM_PROVIDER=anthropic
KINE_LLM_MODELE=claude-sonnet-5
ANTHROPIC_API_KEY=

# Alternative (defaut du code) : provider Mistral. Laisser vide au pilote.
#   KINE_LLM_PROVIDER=mistral   (ou ne rien mettre : c'est le defaut de llm.py)
#   Cle a creer sur https://console.mistral.ai
# Cote serveur uniquement : jamais envoyee au navigateur. Sans cle OCR => app sans OCR.
MISTRAL_API_KEY=

# 1 en dev local (http). Retirer/0 en prod HTTPS pour un cookie Secure.
COOKIE_INSECURE=1
