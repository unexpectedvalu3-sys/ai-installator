# Copier en .env et remplir.  ── Comparateur Courtier ──

# --- Clés IA ---
ANTHROPIC_API_KEY=sk-ant-xxxxx        # prose fine (courrier de synthèse, justification DDA)
OPENROUTER_API_KEY=sk-or-xxxxx        # comparateur (GLM 5.2, gros volume pas cher)
# LLM_MODEL=claude-sonnet-4-6         # modèle Claude par défaut
# COMPARE_MODEL=z-ai/glm-5.2          # modèle OpenRouter du comparateur

# --- Authentification (généré par : python set_password.py) ---
APP_USER=
APP_PASSWORD_HASH=
SECRET_KEY=

# --- Divers ---
# DATA_DIR=/data                      # dossier persistant (cabinet.json, sessions) — volume en prod
# COOKIE_INSECURE=1                   # DEV LOCAL en http:// uniquement (autorise le cookie sans HTTPS)
